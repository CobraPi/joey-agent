# Joey Agent Environment Configuration
# Copy this file to ~/.joey/.env and fill in the keys you need.
# Values here override matching keys in ~/.joey/config.yaml.
#
# You only need a key for the provider you actually use. Set the active
# provider and model with `joey config set model.provider <name>` and
# `joey config set model.default <model>` (or `joey model`).

# =============================================================================
# LLM PROVIDERS (set at least one)
# =============================================================================

# OpenRouter — one API for many models (the default base URL).
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Anthropic — native Messages API (extended thinking supported).
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# OpenAI
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Nous Portal (inference-api.nousresearch.com)
# NOUS_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Groq
# GROQ_API_KEY=

# Google AI Studio / Gemini (OpenAI-compatible endpoint)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# xAI (Grok)
# XAI_API_KEY=

# Z.ai (GLM)
# GLM_API_KEY=

# Ollama (local) — usually needs no key
# OLLAMA_API_KEY=

# =============================================================================
# TOOL KEYS (optional)
# =============================================================================

# Web search (web_search tool)
# TAVILY_API_KEY=

# =============================================================================
# RUNTIME
# =============================================================================

# Override the state directory (default: ~/.joey)
# JOEY_HOME=

# Log filter, like RUST_LOG (e.g. joey=debug,warn)
# JOEY_LOG=

# Override the timezone used for timestamps (IANA name, e.g. America/New_York)
# JOEY_TIMEZONE=

# Auto-approve dangerous operations without prompting
# JOEY_YOLO_MODE=0

# Overall provider request timeout in seconds (default 1800)
# JOEY_API_TIMEOUT=1800
